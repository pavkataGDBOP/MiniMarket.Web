@model IEnumerable<MiniMarket.Services.Models.OrderViewModel>

<h2 class="mb-4">📦 All Orders</h2>

@foreach (var order in Model)
{
    <a class="btn btn-sm btn-success mt-2"
           asp-action="Complete"
           asp-route-id="@order.Id">
        ✔ Mark as Completed
    </a>
    <div class="card mb-4 shadow-sm">
        <div class="card-body">

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="mb-0">Order #@order.Id</h5>
                <span class="text-muted">@order.CreatedOn</span>
            </div>

            <!-- Customer info -->
            <p class="mb-1">
                <strong>Customer:</strong> @order.FirstName @order.LastName
            </p>

            <p class="mb-1">
                <strong>User:</strong> @order.UserId |
                <strong>Email:</strong> @order.Email
            </p>

            <p class="mb-1">
                <strong>Address:</strong> @order.Address
            </p>

            <p class="mb-3">
                <strong>Total:</strong>
                <span class="text-success fw-bold">
                    @order.TotalPrice.ToString("0.00") €
                </span>

                @if (order.PaymentMethod == "Card")
                {
                    <span class="badge bg-primary ms-2">Paid with Card</span>
                }
                else
                {
                    <span class="badge bg-secondary ms-2">Cash</span>
                }
            </p>

            <!-- Products -->
            <h6>Products:</h6>
            <ul class="list-group">
                @foreach (var item in order.Items)
                {
                    <li class="list-group-item d-flex justify-content-between">
                        <span>@item.ProductName</span>
                        <span>x@(item.Quantity)</span>
                    </li>
                }
            </ul>

        </div>
    </div>
}