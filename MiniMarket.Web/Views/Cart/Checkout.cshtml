@model MiniMarket.Services.Models.CheckoutDto

<h2 class="mb-4">🧾 Checkout</h2>

<!-- 🛒 CART SUMMARY -->
<div class="mb-4">
    <h4>Products:</h4>

    <ul class="list-group mb-3">
        @foreach (var item in ViewBag.Cart)
        {
            <li class="list-group-item d-flex justify-content-between">
                <span>@item.Name (x@(item.Quantity))</span>
                <strong>@(item.Price * item.Quantity) €</strong>
            </li>
        }
    </ul>

    <h5>Total: @ViewBag.Total €</h5>
</div>

<form method="post" class="col-md-6">
    <div class="mb-3">
        <label class="form-label">First Name</label>
        <input asp-for="FirstName" class="form-control" />
        <span asp-validation-for="FirstName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Last Name</label>
        <input asp-for="LastName" class="form-control" />
        <span asp-validation-for="LastName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Address</label>
        <input asp-for="Address" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Payment Method</label>
        <select asp-for="PaymentMethod" class="form-select" id="paymentSelect">
            <option value="">-- Select --</option>
            <option value="Cash">Cash</option>
            <option value="Card">Card</option>
        </select>
    </div>

    <!-- 💳 CARD SECTION -->
    <div id="cardSection" style="display:none;">

        <div class="mb-3">
            <input asp-for="CardNumber"
                   id="cardInput"
                   class="form-control"
                   inputmode="numeric"
                   placeholder="XXXX XXXX XXXX XXXX" />
                <span asp-validation-for="CardNumber" class="text-danger"></span>

        </div>

        <div class="mb-3">
            <label>Card Holder</label>
            <input asp-for="CardHolder" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Expiry</label>
            <input asp-for="Expiry" class="form-control" placeholder="MM/YY" />
        </div>

        <div class="mb-3">
            <label class="form-label">CVV</label>
            <input asp-for="CVV"
                   class="form-control"
                   maxlength="3"
                   inputmode="numeric" />
            <span asp-validation-for="CVV" class="text-danger"></span>
        </div>

    </div>

    <button type="submit" class="btn btn-success">Confirm Order</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const select = document.getElementById("paymentSelect");
            const cardSection = document.getElementById("cardSection");

            function toggleCard() {
                if (select.value === "Card") {
                    cardSection.style.display = "block";
                } else {
                    cardSection.style.display = "none";
                }
            }

            // при смяна
            select.addEventListener("change", toggleCard);

            // при зареждане (много важно!)
            toggleCard();
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const input = document.getElementById("cardInput");

            if (!input) return;

            input.addEventListener("input", function (e) {

                let value = e.target.value.replace(/\D/g, '');

                // 🔥 ограничение до 16 цифри
                value = value.substring(0, 16);

                // групиране по 4
                value = value.match(/.{1,4}/g)?.join(' ') || '';

                e.target.value = value;
            });

        });
    </script>
}