@model List<MiniMarket.Services.Models.CartItemDto>

<h2 class="mb-4">🛒 Your Cart</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Your cart is empty.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">

            <thead class="table-dark">
                <tr>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Total</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>

                        <!-- PRODUCT (image + name) -->
                        <td>
                            <div class="d-flex align-items-center">

                                <img src="@(item.ImageUrl ?? "/images/no-image.png")"
                                     width="70"
                                     height="70"
                                     style="object-fit:contain; background:#f8f9fa; border:1px solid #eee; margin-right:10px;" />

                                <span>@item.Name</span>
                            </div>
                        </td>

                        <!-- PRICE -->
                        <td>
                            @item.Price.ToString("0.00") €
                        </td>

                        <!-- QUANTITY -->
                        <td>
                            <div class="d-flex align-items-center">

                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-action="UpdateQuantity"
                                   asp-route-id="@item.ProductId"
                                   asp-route-change="-1">-</a>

                                <span class="mx-2">@item.Quantity</span>

                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-action="UpdateQuantity"
                                   asp-route-id="@item.ProductId"
                                   asp-route-change="1">+</a>
                            </div>
                        </td>

                        <!-- TOTAL -->
                        <td class="fw-bold text-success">
                            @(item.Price * item.Quantity)€
                        </td>

                        <!-- REMOVE -->
                        <td>
                            <a class="btn btn-danger btn-sm"
                                   asp-action="Remove"
                                   asp-route-id="@item.ProductId">
                                Remove
                            </a>
                        </td>

                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- SUMMARY -->
    <div class="d-flex justify-content-between align-items-center mt-4 p-3 border rounded bg-light">

        <h4 class="mb-0">
            Total:
            <span class="text-success fw-bold">
                @Model.Sum(x => x.Price * x.Quantity).ToString("0.00") €
            </span>
        </h4>

        <a class="btn btn-success btn-lg" asp-action="Checkout">
            Checkout
        </a>
    </div>
}