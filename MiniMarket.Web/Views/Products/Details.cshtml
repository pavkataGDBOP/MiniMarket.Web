@model MiniMarket.Services.Models.ProductViewModel

<div class="container mt-4">

    <div class="row">

        <!-- IMAGE -->
        <div class="col-md-6 text-center">
            <div style="height:400px; display:flex; align-items:center; justify-content:center; background:#f8f9fa; border:1px solid #eee;">
                <img src="@(Model.ImageUrl ?? "/images/no-image.png")"
                     style="max-height:100%; max-width:100%; object-fit:contain;" />
            </div>
        </div>

        <!-- DETAILS -->
        <div class="col-md-6">

            <h2 class="mb-3">@Model.Name</h2>

            <p class="text-muted mb-2">
                Category: <strong>@Model.CategoryName</strong>
            </p>

            <!-- PRICE -->
            <h3 class="text-success mb-4">
                @Model.Price.ToString("0.00") €
            </h3>

            <div class="mb-3 text-warning fs-4">
                @{
                    var fullStars = (int)Model.AverageRating;
                    var emptyStars = 5 - fullStars;
                }

                @for (int i = 0; i < fullStars; i++)
                {
                    <span>★</span>
                }

                @for (int i = 0; i < emptyStars; i++)
                {
                    <span>☆</span>
                }

                <span class="text-muted fs-6">
                    (@Model.AverageRating.ToString("0.0"))
                </span>
            </div>
            @if (ViewBag.CanRate == true)
            {
                <div class="mt-4">
                    <h5>Rate this product</h5>

                    <form asp-action="Rate" method="post">
                        <input type="hidden" name="productId" value="@Model.Id" />

                        <select name="value" class="form-select mb-2">
                            <option value="1">1 ⭐</option>
                            <option value="2">2 ⭐</option>
                            <option value="3">3 ⭐</option>
                            <option value="4">4 ⭐</option>
                            <option value="5">5 ⭐</option>
                        </select>

                        <button class="btn btn-warning">Submit Rating</button>
                    </form>
                </div>
            }
            else if (ViewBag.AlreadyRated == true)
            {
                <p class="text-success mt-3">
                    ✅ You have already rated this product.
                </p>
            }

            <!-- DESCRIPTION -->
            <div class="mb-4">
                <h5>Description</h5>
                <p class="text-dark">
                    @(string.IsNullOrWhiteSpace(Model.Description) ? "No description available." : Model.Description)
                </p>
            </div>

            <!-- BUTTON -->
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="btn btn-success btn-lg w-100"
                       asp-controller="Cart"
                       asp-action="Add"
                       asp-route-id="@Model.Id">
                    🛒 Add to Cart
                </a>
            }
            else
            {
                <a class="btn btn-secondary btn-lg w-100"
                       asp-area="Identity"
                       asp-page="/Account/Login">
                    Login to Buy
                </a>
            }

        </div>
    </div>

</div>