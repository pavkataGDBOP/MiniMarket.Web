@model IEnumerable<MiniMarket.Services.Models.ProductViewModel>

<h2 class="mb-4">🛍 Products</h2>


<div class="d-flex flex-wrap gap-2 mb-4">
    @foreach (var category in ViewBag.Categories)
    {
        <a class="btn btn-lg btn-primary"
               asp-action="Index"
               asp-route-categoryId="@category.Id">
            @category.Name
        </a>
    }

    <a class="btn btn-lg btn-secondary" asp-action="Index">
        All
    </a>
</div>



@if (User.IsInRole("Admin"))
{
    <div class="mb-4">
        <a class="btn btn-primary me-2" asp-action="Create">+ Create Product</a>
        <a class="btn btn-warning" asp-controller="Categories" asp-action="Create">
            + Add Category
        </a>
    </div>
}


<form method="get" class="mb-4 d-flex">
    <input type="text"
           name="search"
           value="@ViewBag.Search"
           class="form-control me-2"
           placeholder="Search products..." />

    <input type="hidden" name="categoryId" value="@ViewBag.SelectedCategory" />

    <button type="submit" class="btn btn-dark">
        🔍
    </button>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No products available.
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100 shadow-sm">

                    <a asp-action="Details" asp-route-id="@item.Id">
                        <div style="height:200px; display:flex; align-items:center; justify-content:center; background:#f8f9fa; border-bottom:1px solid #eee;">
                            <img src="@(item.ImageUrl ?? "/images/no-image.png")"
                                 style="max-height:100%; max-width:100%; object-fit:contain;" />
                        </div>
                    </a>

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                                @item.Name
                            </a>
                        </h5>

                        <p class="text-muted mb-1">@item.CategoryName</p>

                        <h6 class="text-success mb-3">
                            @item.Price.ToString("0.00") €
                        </h6>

                        <div class="mb-2 text-warning">
                            @{
                                var fullStars = (int)item.AverageRating;
                                var emptyStars = 5 - fullStars;
                            }

                            @for (int i = 0; i < fullStars; i++)
                            {
                                <span>★</span>
                            }

                            @for (int i = 0; i < emptyStars; i++)
                            {
                                <span>☆</span>
                            }

                            <small class="text-muted">(@item.AverageRating.ToString("0.0"))</small>
                        </div>

                        <div class="mt-auto">

                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <a class="btn btn-success w-100 mb-2"
                                       asp-controller="Cart"
                                       asp-action="Add"
                                       asp-route-id="@item.Id">
                                    Add to Cart
                                </a>
                            }
                            else
                            {
                                <a class="btn btn-secondary w-100 mb-2"
                                       asp-area="Identity"
                                       asp-page="/Account/Login">
                                    Login to Buy
                                </a>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <a class="btn btn-warning w-100 mb-2"
                                       asp-action="Edit"
                                       asp-route-id="@item.Id">
                                    Edit
                                </a>

                                <a class="btn btn-danger w-100"
                                       asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       onclick="return confirm('Are you sure?');">
                                    Delete
                                </a>
                            }
                            

                        </div>
                    </div>

                </div>
            </div>
        }
        @if (ViewBag.TotalPages > 1)
        {
            <nav>
                <ul class="pagination justify-content-center">

                                        
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(ViewBag.CurrentPage - 1)"
                               asp-route-categoryId="@ViewBag.SelectedCategory"
                               asp-route-search="@ViewBag.Search">
                            Previous
                        </a>
                    </li>

                                       
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-categoryId="@ViewBag.SelectedCategory"
                                   asp-route-search="@ViewBag.Search">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(ViewBag.CurrentPage + 1)"
                               asp-route-categoryId="@ViewBag.SelectedCategory"
                               asp-route-search="@ViewBag.Search">
                            Next
                        </a>
                    </li>

                </ul>
            </nav>
        }
    </div>
}