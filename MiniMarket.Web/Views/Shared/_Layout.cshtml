<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MiniMarket</title>

   
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
 

</head>

<body>

   
   
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success text-center mb-0 rounded-0">
            @TempData["SuccessMessage"]
        </div>
    }

    
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container">

                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    🛒 MiniMarket
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">

                    
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Products" asp-action="Index">
                                Products
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cart" asp-action="Index">
                                Cart
                            </a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Orders">
                                    Pending Orders
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Completed">
                                    Completed Orders
                                </a>
                            </li>
                        }

                    </ul>

                    
                    <ul class="navbar-nav">

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-light">
                                    👋 Hello, @User.Identity.Name
                                </span>
                            </li>

                            <li class="nav-item">
                                <form asp-area="Identity"
                                      asp-page="/Account/Logout"
                                      method="post"
                                      class="d-inline">
                                    <button class="btn btn-outline-light btn-sm ms-2" type="submit">
                                        Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-area="Identity"
                                       asp-page="/Account/Login">
                                    Login
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-area="Identity"
                                       asp-page="/Account/Register">
                                    Register
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>

   
    <main class="container mt-4">
        @RenderBody()
    </main>

    
    <footer class="text-center text-muted mt-5 mb-3">
        <small>© 2026 MiniMarket</small>
    </footer>

    
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
    

</body>
</html>
